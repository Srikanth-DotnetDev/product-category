@page "{id:int}"
@model AprilPractice.Web.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}

<div class="container mt-4">
    <h1>Delete Product</h1>
    <hr />
    
    <div class="alert alert-danger">
        <h4 class="alert-heading">Are you sure you want to delete this product?</h4>
    </div>
    
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Product.Name</dd>
                
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Product.Description</dd>
                
                <dt class="col-sm-3">Price</dt>
                <dd class="col-sm-9">@Model.Product.Price.ToString("C")</dd>
                
                <dt class="col-sm-3">Stock</dt>
                <dd class="col-sm-9">@Model.Product.Stock</dd>
                
                <dt class="col-sm-3">Category</dt>
                <dd class="col-sm-9">@Model.Product.Category?.Name</dd>
            </dl>
        </div>
    </div>
    
    <form method="post" class="mt-3">
        <input type="hidden" asp-for="Product.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
