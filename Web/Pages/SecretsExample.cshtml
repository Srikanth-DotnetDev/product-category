@page
@model Web.Pages.SecretsExampleModel
@{
    ViewData["Title"] = "Azure Key Vault Example";
}

<h1>Azure Key Vault Secrets Example</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning">
        <strong>Warning:</strong> @Model.ErrorMessage
    </div>
}
else
{
    <div class="card mb-3">
        <div class="card-header">
            <h5>Retrieved Secrets</h5>
        </div>
        <div class="card-body">
            <p><strong>Connection String:</strong> 
                @(string.IsNullOrEmpty(Model.ConnectionString) ? "Not found" : "********** (hidden for security)")
            </p>
            <p><strong>API Key:</strong> 
                @(string.IsNullOrEmpty(Model.ApiKey) ? "Not found" : "********** (hidden for security)")
            </p>
        </div>
    </div>
}

<h2>How to Set Up Azure Key Vault</h2>

<ol>
    <li>Create an Azure Key Vault in the Azure Portal</li>
    <li>Add secrets to your Key Vault (e.g., <code>DatabaseConnectionString</code>, <code>ExternalApiKey</code>)</li>
    <li>Update <code>appsettings.json</code> with your Key Vault URL</li>
    <li>Configure authentication:
        <ul>
            <li><strong>Local Development:</strong> Sign in via Azure CLI (<code>az login</code>) or Visual Studio</li>
            <li><strong>Azure Deployment:</strong> Enable Managed Identity for your App Service</li>
        </ul>
    </li>
    <li>Grant your identity access to Key Vault secrets (Key Vault Access Policies or RBAC)</li>
</ol>
