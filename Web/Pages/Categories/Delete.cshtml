@page "{id:int}"
@model AprilPractice.Web.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = "Delete Category";
}

<div class="container mt-4">
    <h1>Delete Category</h1>
    <hr />
    
    <div class="alert alert-danger">
        <h4 class="alert-heading">Are you sure you want to delete this category?</h4>
        @if (Model.Category.Products.Any())
        {
            <p class="mb-0"><strong>Warning:</strong> This category has @Model.Category.Products.Count product(s) associated with it.</p>
        }
    </div>
    
    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Category.Name</dd>
                
                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Category.Description</dd>
                
                <dt class="col-sm-3">Products</dt>
                <dd class="col-sm-9">@Model.Category.Products.Count</dd>
            </dl>
        </div>
    </div>
    
    <form method="post" class="mt-3">
        <input type="hidden" asp-for="Category.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
