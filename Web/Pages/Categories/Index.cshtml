@page
@model AprilPractice.Web.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Categories</h1>
        <a asp-page="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add New Category
        </a>
    </div>

    <div class="row">
        @foreach (var category in Model.Categories)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0">@category.Name</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">@category.Description</p>
                        <p class="text-muted">
                            <i class="bi bi-box"></i> @category.Products.Count products
                        </p>
                    </div>
                    <div class="card-footer">
                        <a asp-page="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-page="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-danger">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
